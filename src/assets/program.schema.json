{
    "$schema": "https://json-schema.org/draft-07/schema#",

    "definitions": {
        "MemoryInstruction": {
            "type": "object",
            "description": "Instruction for interacting with input and output registers",
            "properties": {
                "type": { "const": "mem" },
                "setInput": {
                    "oneOf": [
                        { "type": "integer" },
                        { "enum": ["in1", "in2"] }
                    ]
                },
                "setShiftCounter": { "type": "number" },

                "comment": { "type": "string" }
            },
            "additionalProperties": false,
            "required": ["type"],
            "anyOf": [
                { "required": ["setInput"] },
                { "required": ["setShiftCounter"] }
            ]
        },
        "JumpInstruction": {
            "type": "object",
            "description": "Instruction for setting the program counter conditionally",
            "properties": {
                "type": { "const": "jmp" },
                "signal": { 
                    "enum": ["c-o", "sgn", "ak0", "sc0", "mq0", "jmp"]
                },
                "if": { "type": "boolean" },
                "line": { "type": "integer" },
                "skip": { "type": "integer"},

                "comment": { "type": "string" }
            },
            "additionalProperties": false,
            "required": ["type", "signal"],
            "oneOf": [
                { "required": ["line"], "not": { "required": ["skip"] } },
                { "required": ["skip"], "not": { "required": ["line"] } }
            ],

            "allOf": [
                {
                    "if": {
                        "properties": { "signal": {"const": "jmp"}}
                    },
                    "then": { "required": [] },
                    "else": { "required": ["if"] }
                }
            ]
        },
        "ALUInstruction": {
            "type": "object",
            "description": "Instruction that executes computation",
            "properties": {
                "type": { "const": "alu" },
                "invA": { "type": "boolean", "default": false },
                "invB": { "type": "boolean", "default": false },
                "caIn": { "type": "boolean", "default": false },
                "invC": { "type": "boolean", "default": false },

                "wrAk": { "type": "boolean", "default": false },
                "shAk": { "type": "boolean", "default": false },
                "shMQ": { "type": "boolean", "default": false },
                "rsMQ": { "type": "boolean", "default": false },
                "shL":  { "type": "boolean", "default": false },
                "rsAk": { "type": "boolean", "default": false },
                "sMQ0": { "type": "boolean", "default": false },
                "rsSC": { "type": "boolean", "default": false },

                "comment": { "type": "string" }
            },
            "additionalProperties": false,
            "required": ["type"]
        },
        "Instruction": {
            "oneOf": [
                { "$ref": "#/definitions/MemoryInstruction" },
                { "$ref": "#/definitions/JumpInstruction" },
                { "$ref": "#/definitions/ALUInstruction" }
            ]
        }
    },

    "type": "object",
    "properties": {
        "$schema": { "type": "string" },

        "name": {
            "type": "string",
            "description": "Name of the program"
        },
        "unit": {
            "enum": ["int", "float"],
            "description": "The unit to execute the program"
        },
        "instructions": {
            "type": "array",
            "items": { "$ref": "#/definitions/Instruction" }
        }
    },
    "additionalProperties": false,
    "required": ["unit", "instructions"]
}